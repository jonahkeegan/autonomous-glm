{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExpectedFindingsResult",
  "description": "Schema for expected audit findings in golden dataset",
  "type": "object",
  "required": ["screenshot_id", "name", "expected_findings", "tolerance", "created"],
  "properties": {
    "screenshot_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the screenshot"
    },
    "name": {
      "type": "string",
      "description": "Screenshot name (without extension)"
    },
    "expected_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dimension", "issue", "severity", "location", "rationale"],
        "properties": {
          "dimension": {
            "type": "string",
            "description": "Audit dimension",
            "enum": [
              "visual_hierarchy",
              "spacing_rhythm",
              "typography",
              "color",
              "alignment_grid",
              "components",
              "density",
              "iconography",
              "empty_states",
              "loading_states",
              "error_states",
              "theming",
              "accessibility"
            ]
          },
          "issue": {
            "type": "string",
            "description": "Issue type identifier"
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"],
            "description": "Expected severity level"
          },
          "location": {
            "type": "object",
            "description": "Location of the issue",
            "properties": {
              "component_ids": {
                "type": "array",
                "items": { "type": "string" }
              },
              "bounding_box": {
                "type": "object",
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" },
                  "w": { "type": "number" },
                  "h": { "type": "number" }
                }
              }
            }
          },
          "rationale": {
            "type": "string",
            "description": "Explanation of why this is an issue"
          }
        }
      }
    },
    "tolerance": {
      "type": "object",
      "description": "Validation tolerance settings",
      "properties": {
        "severity_flexibility": {
          "type": "boolean",
          "description": "Allow severity level flexibility (e.g., high vs medium)"
        },
        "max_extra_findings": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum number of extra findings allowed"
        }
      }
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp"
    }
  }
}